# ─── SERVER ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── DATABASE ──────────────────────────────────────────────
# Local:   mongodb://localhost:27017/restora
# Atlas:   mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/restora?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/restora

# ─── AUTH ──────────────────────────────────────────────────
# Use a long random string in production (openssl rand -base64 64)
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRE=30d

# ─── CORS ──────────────────────────────────────────────────
# Local:      http://localhost:5173
# Production: https://your-app.vercel.app
# Multiple:   https://your-app.vercel.app,https://custom-domain.com
CLIENT_URL=http://localhost:5173
