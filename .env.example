# ─── SERVER ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development   # set to "production" on Render

# ─── DATABASE ──────────────────────────────────────────────
# Local:  mongodb://localhost:27017/restora
# Atlas:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/restora?retryWrites=true&w=majority&appName=Restora
MONGO_URI=mongodb://localhost:27017/restora

# ─── AUTH ──────────────────────────────────────────────────
# IMPORTANT: use a strong random secret in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRE=30d

# ─── CORS ──────────────────────────────────────────────────
# No trailing slash!
# Local:       http://localhost:5173
# Production:  https://restora-frontend.vercel.app
# Multiple:    https://restora-frontend.vercel.app,https://custom-domain.com
CLIENT_URL=http://localhost:5173
